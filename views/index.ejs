<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quora · Feed</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar">
    <a href="/posts" class="navbar-brand">
      <span class="brand-dot"></span>
      Quora
    </a>
    <div class="navbar-actions">
      <a href="/posts/new" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Post
      </a>
    </div>
  </nav>

  <!-- Main content -->
  <div class="page-container">
    <div class="page-header">
      <h1>What's on your <span>mind?</span></h1>
      <span class="post-count"><%= posts.length %> Posts</span>
    </div>

    <% if (posts.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">✦</div>
        <p>No posts yet. Be the first to share something.</p>
        <a href="/posts/new" class="btn btn-primary">Write a Post</a>
      </div>
    <% } else { %>
      <div class="posts-feed">
        <% for (let post of posts) { %>
          <div class="post-card">
            <div class="post-card-header">
              <div class="avatar"><%= post.username.charAt(0).toUpperCase() %></div>
              <div class="post-meta">
                <span class="post-username"><%= post.username %></span>
                <span class="post-handle">@<%= post.username.toLowerCase().replace(/\s+/g, '') %></span>
              </div>
            </div>
            <p class="post-content"><%= post.content %></p>
            <div class="post-actions">
              <a href="/posts/<%= post.id %>" class="btn-link">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Read more
              </a>
              <a href="/posts/<%= post.id %>/edit" class="btn btn-edit">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit
              </a>
              <form method="post" action="/posts/<%= post.id %>?_method=DELETE" onsubmit="return confirm('Delete this post?')">
                <button type="submit" class="btn btn-danger">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                  Delete
                </button>
              </form>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

</body>
</html>
