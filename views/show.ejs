<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.username %> · Post</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar">
    <a href="/posts" class="navbar-brand">
      <span class="brand-dot"></span>
      Quora
    </a>
    <div class="navbar-actions">
      <a href="/posts/new" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Post
      </a>
    </div>
  </nav>

  <div class="page-container">
    <a href="/posts" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      Back to feed
    </a>

    <div class="post-detail-card">
      <span class="post-id-badge">ID: <%= post.id %></span>

      <div class="post-card-header">
        <div class="avatar" style="width:48px;height:48px;font-size:1.2rem;">
          <%= post.username.charAt(0).toUpperCase() %>
        </div>
        <div class="post-meta">
          <span class="post-username" style="font-size:1.05rem;"><%= post.username %></span>
          <span class="post-handle">@<%= post.username.toLowerCase().replace(/\s+/g, '') %></span>
        </div>
      </div>

      <div class="post-content-full"><%= post.content %></div>

      <div class="post-actions">
        <a href="/posts/<%= post.id %>/edit" class="btn btn-edit">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit post
        </a>
        <form method="post" action="/posts/<%= post.id %>?_method=DELETE" onsubmit="return confirm('Delete this post?')">
          <button type="submit" class="btn btn-danger">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
            Delete post
          </button>
        </form>
      </div>
    </div>
  </div>

</body>
</html>
